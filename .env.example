# ─── A Treatise on the Hostile Mesh ──────────────────────────────────────────
# Copy to `.env` and fill in. Anything left blank degrades gracefully (the UI
# will surface the missing capability honestly — no fake confirmations).

# ─── LLM provider ────────────────────────────────────────────────────────────
# We support two providers, picked automatically by which key you supply
# (or explicitly via HOSTILE_MESH_LLM_PROVIDER=openrouter|anthropic).
#
# OpenRouter / OpenAI-compatible — set a generic `API_KEY` here:
API_KEY=
# Optionally override the OpenRouter base URL (defaults to https://openrouter.ai/api/v1):
# BASE_URL=https://openrouter.ai/api/v1

# Or Anthropic direct:
ANTHROPIC_API_KEY=

# Optional explicit selection. If unset, we infer from whichever key is set.
# HOSTILE_MESH_LLM_PROVIDER=openrouter

# Models. Defaults are tuned for COST: a full 3-min match costs ~$0.05–$0.15
# in LLM spend with the defaults below. To run with stronger (more expensive)
# agents, override:
#   HOSTILE_MESH_COMBATANT_MODEL=anthropic/claude-sonnet-4.5    (~50× cost)
#   HOSTILE_MESH_COMBATANT_MODEL=openai/gpt-4o                  (~30× cost)
#   HOSTILE_MESH_COMBATANT_MODEL=anthropic/claude-haiku-4.5     (~5× cost)
#
# Defaults: openai/gpt-4o-mini for both combatants and chorus.
# HOSTILE_MESH_COMBATANT_MODEL=
# HOSTILE_MESH_CHORUS_MODEL=

# Per-call output cap. Lower → cheaper. 1024 is plenty for combat reasoning.
HOSTILE_MESH_MAX_TOKENS=1024

# Hard ceiling on agent loop turns per match. Lower → cheaper, less play.
HOSTILE_MESH_MAX_TURNS=12

# ─── ENS (Sepolia) ───────────────────────────────────────────────────────────
# Parent name we own on Sepolia. Subnames for combatants, chorus members,
# matches, wounds, patches, and spectator grants are minted under it.
HOSTILE_MESH_ENS_PARENT=hostilemesh.eth

# Sepolia JSON-RPC. Prefer Alchemy/Infura; the public node works in a pinch.
HOSTILE_MESH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Hex private key (0x...) for the registrar wallet that owns the parent name
# and pays for subname/text-record writes during a match. Generate locally;
# keep it out of source control. NEVER reuse a mainnet key here.
HOSTILE_MESH_REGISTRAR_PRIVKEY=

# Where per-agent encrypted keystores live. One JSON keystore per agent ID.
HOSTILE_MESH_KEYSTORE_DIR=./.keystore

# Passphrase used to encrypt agent keystores at rest. REQUIRED — refuses to
# write plaintext keystores even in dev.
HOSTILE_MESH_KEYSTORE_PASSPHRASE=

# ─── AXL multi-node mesh ─────────────────────────────────────────────────────
# Path to the compiled AXL `node` binary. Built via `make build` in the AXL
# repo. `scripts/bootstrap.sh` does this for you.
HOSTILE_MESH_AXL_BINARY=./infra/axl/node

# Where per-node configs (node-config.json) and ed25519 keys live.
HOSTILE_MESH_AXL_RUNTIME_DIR=./.axl

# Base ports — each node gets a unique offset.
HOSTILE_MESH_AXL_BASE_API_PORT=9100
HOSTILE_MESH_AXL_BASE_TCP_PORT=7100
HOSTILE_MESH_AXL_HUB_LISTEN_PORT=9001

# ─── Arena API ───────────────────────────────────────────────────────────────
HOSTILE_MESH_ARENA_HOST=127.0.0.1
HOSTILE_MESH_ARENA_PORT=8787

# ─── Vulnerable target services ──────────────────────────────────────────────
HOSTILE_MESH_TARGET_BASE_PORT=8800

# ─── Match defaults ──────────────────────────────────────────────────────────
HOSTILE_MESH_MATCH_DURATION_SECONDS=180
HOSTILE_MESH_BUGS_PER_COMBATANT=4
